<!DOCTYPE html>
<html lang="zh">
<head>
<meta charset="utf-8">
<title>FinSynapse · {{ asof }}</title>
<meta name="viewport" content="width=device-width, initial-scale=1">
<style>
  :root {
    --bg: #FAFAFA;
    --surface: #FFFFFF;
    --border: #E5E7EB;
    --text: #111827;
    --text-muted: #6B7280;
    --accent: #2E86AB;
  }
  * { box-sizing: border-box; }
  body {
    margin: 0;
    font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Hiragino Sans GB",
                 "Microsoft YaHei", "Noto Sans CJK SC", "Segoe UI", Roboto, sans-serif;
    background: var(--bg);
    color: var(--text);
    -webkit-font-smoothing: antialiased;
    line-height: 1.7;
  }
  header {
    background: var(--surface);
    border-bottom: 1px solid var(--border);
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
  }
  header .crumbs a {
    color: var(--text-muted);
    text-decoration: none;
    font-size: 13px;
    margin-right: 12px;
  }
  header .crumbs a:hover { color: var(--accent); }
  header .actions a {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 6px;
    padding: 6px 12px;
    color: var(--text);
    text-decoration: none;
    font-size: 13px;
  }
  header .actions a:hover { background: #F3F4F6; }
  main {
    max-width: 800px;
    margin: 0 auto;
    padding: 32px 24px 80px;
  }
  article {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 32px 40px;
  }
  article h1 { font-size: 22px; margin: 0 0 12px; font-weight: 600; }
  article h2 { font-size: 16px; margin: 28px 0 12px; padding-top: 16px; border-top: 1px solid var(--border); font-weight: 600; }
  article h2:first-of-type { padding-top: 0; border-top: none; }
  article h3 { font-size: 14px; margin: 20px 0 10px; color: var(--text-muted); font-weight: 600; }
  article blockquote {
    margin: 0 0 20px;
    padding: 10px 16px;
    background: #F3F4F6;
    border-left: 3px solid var(--accent);
    color: var(--text-muted);
    font-size: 13px;
    border-radius: 0 4px 4px 0;
  }
  article p { margin: 0 0 14px; font-size: 14px; }
  article code { background: #F3F4F6; padding: 1px 6px; border-radius: 3px; font-size: 12px; }
  article table { width: 100%; border-collapse: collapse; font-size: 13px; margin: 12px 0 20px; }
  article th, article td { text-align: left; padding: 8px 10px; border-bottom: 1px solid var(--border); }
  article th { font-weight: 500; color: var(--text-muted); background: #F9FAFB; }
  article td:nth-child(n+3) { font-variant-numeric: tabular-nums; }
  article ul { padding-left: 22px; margin: 8px 0 14px; }
  article hr { border: none; border-top: 1px solid var(--border); margin: 24px 0; }
  footer { color: var(--text-muted); font-size: 12px; text-align: center; padding: 24px; }
</style>
</head>
<body>
<header>
  <div class="crumbs">
    <a href="../index.html">🌡️ FinSynapse</a>
    <a href="../briefs.html">{{ tx.single_back_to_archive }}</a>
  </div>
  <div class="actions">
    <a href="{{ asof }}.md" download>{{ tx.single_download_md }}</a>
  </div>
</header>
<main>
  <article>
    {{ body_html | safe }}
  </article>
</main>
<footer>{{ tx.footer }}</footer>
</body>
</html>
